#include <stdio.h>

int main() {
    
    float x1, x2, x3, resultado;
    
    printf("Digite o 1º valor: ");
    scanf("%f", &x1);
    
    printf("Digite o 2º valor: ");
    scanf("%f", &x2);
    
    printf("Digite o 3º valor: ");
    scanf("%f", &x3);
    
    resultado = (x1+x2+x3)/3;
    
    printf("\nA média entre eles é: %.2f", resultado);
    return 0;
}
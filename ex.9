#include <stdio.h>

int main() {
   
    int valor_1, valor_2, aux;
   
    printf("Digite o primeiro número: ");
    scanf("%d", &valor_1);
   
    printf("Digite o segundo número: ");
    scanf("%d", &valor_2);
   
    aux = valor_1;
    valor_1 = valor_2;
    valor_2 = aux;
   
    printf("\nResultado:\nValor 1 = %d\nValor 2 = %d", valor_1, valor_2);
   
    return 0;
}
#include <stdio.h>

int main() {
    
    int h, min, conta;
    
    printf("Digite a quantidade de horas: ");
    scanf("%d", &h);
    
    printf("Digite a quantidade dos minutos: ");
    scanf("%d", &min);
    
    conta = h*60 + min;
    
    printf("\nJá se passaram %d minutos!", conta);
    return 0;
}